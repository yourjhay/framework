<?php

namespace App\Models;

use Simple\Model;

class User extends Model
{
    protected $table = 'users';

    protected $fillable = [
        'name',
        'email',
        'password_hash',
        'email_verified_at',
    ];

    public $timestamps = true;

    public static function findByEmail(string $email): ?self
    {
        return self::where('email', $email)->first();
    }
}
